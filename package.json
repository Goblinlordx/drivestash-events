{
  "name": "drivestash-events",
  "version": "0.0.2",
  "description": "Append-only event log with offline-first sync via drivestash",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goblinlordx/drivestash-events.git"
  },
  "homepage": "https://github.com/Goblinlordx/drivestash-events#readme",
  "bugs": {
    "url": "https://github.com/Goblinlordx/drivestash-events/issues"
  },
  "keywords": [
    "event-sourcing",
    "event-log",
    "offline-first",
    "google-drive",
    "drivestash",
    "projection",
    "sync",
    "append-only",
    "ulid",
    "multi-device"
  ],
  "author": "Goblinlordx",
  "peerDependencies": {
    "drivestash": "^0.0.2"
  },
  "devDependencies": {
    "drivestash": "^0.0.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT"
}
